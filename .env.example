# API base URL for the Newsletter Preferences backend.
# HTTPS profile (preferred — matches Vite dev server which also runs over HTTPS).
VITE_API_BASE_URL=https://localhost:7287
# Plain HTTP fallback (uncomment if you launch the backend with the http profile):
# VITE_API_BASE_URL=http://localhost:5289

# Keycloak (admin single sign-on). Must match the realm imported by the backend
# (NPS repo: keycloak/realm-export.json). The Keycloak dev server runs on :8080.
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=nps
VITE_KEYCLOAK_CLIENT_ID=nps-admin-spa
